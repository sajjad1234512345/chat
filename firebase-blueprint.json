{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "A custom event created by a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the event" },
        "description": { "type": "string", "description": "Description of the event" },
        "image": { "type": "string", "description": "URL of the event cover photo" },
        "startDate": { "type": "string", "format": "date-time", "description": "Start date of the event" },
        "endDate": { "type": "string", "format": "date-time", "description": "End date of the event" },
        "openingTime": { "type": "string", "description": "Opening time of the event" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "visibility": { "type": "string", "enum": ["public", "private"] },
        "participation": { "type": "string", "enum": ["free", "paid"] },
        "price": { "type": "number" },
        "hostId": { "type": "string", "description": "UID of the host" },
        "participants": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "startDate", "endDate", "location", "hostId"]
    },
    "Accommodation": {
      "title": "Accommodation",
      "description": "A rental property listed on the map.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the property" },
        "description": { "type": "string", "description": "Description of the property" },
        "image": { "type": "string", "description": "URL of the property photo" },
        "pricePerNight": { "type": "number", "description": "Price per night" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "availableDates": { "type": "array", "items": { "type": "string" } },
        "bookedDates": { "type": "array", "items": { "type": "string" } },
        "whatsapp": { "type": "string" },
        "phone": { "type": "string" },
        "hostId": { "type": "string" }
      },
      "required": ["name", "pricePerNight", "location", "hostId"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A booking for an accommodation.",
      "type": "object",
      "properties": {
        "accommodationId": { "type": "string" },
        "guestId": { "type": "string" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "totalCost": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] }
      },
      "required": ["accommodationId", "guestId", "checkIn", "checkOut", "totalCost"]
    }
  },
  "firestore": {
    "/events/{eventId}": { "schema": "Event", "description": "Collection of events" },
    "/accommodations/{accommodationId}": { "schema": "Accommodation", "description": "Collection of accommodations" },
    "/bookings/{bookingId}": { "schema": "Booking", "description": "Collection of bookings" }
  }
}
